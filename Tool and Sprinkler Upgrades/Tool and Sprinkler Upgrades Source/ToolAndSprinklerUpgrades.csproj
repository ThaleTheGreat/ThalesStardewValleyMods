<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net6.0</TargetFramework>
    <AssemblyName>ToolAndSprinklerUpgrades</AssemblyName>
    <RootNamespace>ThaleTheGreat.ToolAndSprinklerUpgrades</RootNamespace>
    <Nullable>enable</Nullable>
    <Version>2.0.1</Version>
    <AssemblyVersion>2.0.1.0</AssemblyVersion>
    <FileVersion>2.0.1.0</FileVersion>
    <InformationalVersion>2.0.1</InformationalVersion>
    <PackageVersion>2.0.1</PackageVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <ModFolderName>Tool and Sprinkler Upgrades</ModFolderName>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Pathoschild.Stardew.ModBuildConfig" Version="4.4.0" PrivateAssets="All" />
    <PackageReference Include="Lib.Harmony" Version="2.3.6" PrivateAssets="All" />
  </ItemGroup>
  <ItemGroup>
    <None Include="manifest.json" CopyToOutputDirectory="PreserveNewest" />
    <None Include="LICENSE" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="assets/**" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="i18n/**" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
</Project>
