<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net6.0</TargetFramework>
    <LangVersion>10.0</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <AssemblyName>WalletTools</AssemblyName>
    <RootNamespace>ThaleTheGreat.WalletTools</RootNamespace>
    <Version>1.7.0</Version>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <ModFolderName>Wallet Tools</ModFolderName>
    <EnableHarmony>true</EnableHarmony>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Pathoschild.Stardew.ModBuildConfig" Version="4.3.0" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <None Include="manifest.json" CopyToOutputDirectory="PreserveNewest" />
    <None Include="LICENSE" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <Target Name="RemoveSourceAssetFoldersFromBuildOutputs" AfterTargets="Build">
    <RemoveDir Directories="$(TargetDir)assets" />
    <RemoveDir Directories="$(OutputPath)assets" />
    <RemoveDir Directories="$(MSBuildProjectDirectory)\..\$(ModFolderName)\assets" />
  </Target>
</Project>
