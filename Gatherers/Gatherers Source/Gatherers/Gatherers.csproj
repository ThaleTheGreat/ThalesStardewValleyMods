<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net6.0</TargetFramework>
    <AssemblyName>Gatherers</AssemblyName>
    <RootNamespace>ThaleTheGreat.Gatherers</RootNamespace>
    <EnableHarmony>true</EnableHarmony>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <Version>1.0.0</Version>
  
    <AssemblyVersion>1.0.0.0</AssemblyVersion>
    <FileVersion>1.0.0.0</FileVersion>
    <InformationalVersion>1.0.0</InformationalVersion>
</PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Pathoschild.Stardew.ModBuildConfig" Version="4.4.0" PrivateAssets="all" />
  </ItemGroup>
  <PropertyGroup>
    <AutomateDllPath Condition="'$(AutomateDllPath)' == ''">$(MSBuildThisFileDirectory)..\lib\Automate.dll</AutomateDllPath>
  </PropertyGroup>
  <ItemGroup>
    <Reference Include="Automate">
      <HintPath>$(AutomateDllPath)</HintPath>
      <Private>false</Private>
    </Reference>
    <None Include="..\lib\Automate.dll" CopyToOutputDirectory="Never" Visible="false" />
  </ItemGroup>
  <ItemGroup>
    <None Include="manifest.json" CopyToOutputDirectory="PreserveNewest" />
    <None Include="LICENSE" CopyToOutputDirectory="PreserveNewest" />
    <None Include="assets\**\*" CopyToOutputDirectory="PreserveNewest" />
    <None Include="i18n\**\*" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
</Project>
