<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <EnableModDeploy>false</EnableModDeploy>
    <EnableModZip>false</EnableModZip>
    <TargetFramework>net6.0</TargetFramework>
    <Version>1.6.0</Version>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <AssemblyName>StarBull</AssemblyName>
    <RootNamespace>ThaleTheGreat.StarBull</RootNamespace>
    <LangVersion>10.0</LangVersion>
    <Nullable>disable</Nullable>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="System\**\*.cs" />
    <Compile Remove="RefSafetyRulesAttribute.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Pathoschild.Stardew.ModBuildConfig" Version="4.4.0" PrivateAssets="all" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Resources\**\*" />
  </ItemGroup>

  <ItemGroup>
    <None Include="manifest.json" CopyToOutputDirectory="PreserveNewest" />
    <None Include="LICENSE" CopyToOutputDirectory="PreserveNewest" />
    <None Include="i18n\**\*" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>


  <Target Name="WriteGameModsPath">
    <Error Condition="'$(GameModsPath)' == ''" Text="The Stardew Valley Mods folder could not be detected." />
    <Error Condition="'$(GameModsPathOutputFile)' == ''" Text="GameModsPathOutputFile was not provided." />
    <WriteLinesToFile File="$(GameModsPathOutputFile)" Lines="$(GameModsPath)" Overwrite="true" />
  </Target>
</Project>
